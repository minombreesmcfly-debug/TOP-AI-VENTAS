rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }

    match /leads/{leadId} {
      allow read, write: if true;
    }

    match /sales_flyers/{flyerId} {
      allow read, write: if true;
    }

    match /team_chat_messages/{messageId} {
      allow read, write: if true;
    }
  }
}
